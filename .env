# ── Configuration du générateur de podcasts ──────────────────────────────────
# Copiez ce fichier en .env et renseignez vos valeurs

# Clé API DeepSeek (obligatoire)
DEEPSEEK_API_KEY=sk-ea95f2a15c484d728d4a7b8d4e59b1dc

# URL de base de l'API (ne pas modifier sauf si vous utilisez un proxy)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Modèle DeepSeek à utiliser
DEEPSEEK_MODEL=deepseek-chat

# Dossiers (relatifs au répertoire courant ou chemins absolus)
INPUT_ROOT_DIR=/content/drive/MyDrive/courses_to_speech/cours
OUTPUT_ROOT_DIR=/content/drive/MyDrive/courses_to_speech/podcasts

# Modèle Kokoro sur Hugging Face (utilisé si le package 'kokoro' n'est pas installé)
KOKORO_MODEL_NAME=hexgrad/Kokoro-82M

# Voix française Kokoro (ff_siwis = femme française, mf_alpha = homme)
KOKORO_VOICE=ff_siwis

# Parallélisme
MAX_WORKERS=10

# Résilience API
RETRY_ATTEMPTS=5
RETRY_BACKOFF_FACTOR=2

# Taille max des notes envoyées à l'API (en tokens approx.)
MAX_INPUT_TOKENS=3500

# Nombre de mots par segment TTS (Kokoro ne gère pas les très longs textes d'un coup)
TTS_CHUNK_WORDS=80

# Qualité MP3
MP3_BITRATE=128k

# Sauvegarder le texte généré par DeepSeek en .txt (true/false)
SAVE_GENERATED_TEXT=true
